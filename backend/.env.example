# ==============================================================
# Job Portal - Backend Environment Variables Template
# ==============================================================

# Database
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Email (Gmail App Password)
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_16_letter_app_password

# JWT Secret (Generate a strong random 64-character hex string)
JWT_SECRET=replace_this_with_a_strong_secret_key_in_production

# Frontend URL (For CORS and Password Reset Links)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Default Admin Account
ADMIN_EMAIL=admin@jobportal.com
ADMIN_PASSWORD=admin123

# Default Security Admin Account
SECURITY_ADMIN_EMAIL=backendteamsecurity@gmail.com
SECURITY_ADMIN_PASSWORD=Dinesh1428@
